<Window x:Class="CortexAV.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CortexAV"
        mc:Ignorable="d"
        Title="CortexAV - Zero-Day Malware Detector" Height="550" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#121212" Foreground="White">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#1E1E1E" Grid.Column="0" CornerRadius="0,15,15,0">
            <StackPanel Margin="10,30,10,10">
                <TextBlock Text="CortexAV" FontSize="26" FontWeight="Bold" Foreground="#00ADB5" HorizontalAlignment="Center" Margin="0,0,0,40"/>

                <Button Content="Dashboard" Background="Transparent" Foreground="White" BorderThickness="0" Height="40" Margin="0,5" FontSize="14" HorizontalContentAlignment="Left" Padding="15,0,0,0" Click="BtnMenuDashboard_Click"/>
                <Button Content="Istoric Scanări" Background="Transparent" Foreground="Gray" BorderThickness="0" Height="40" Margin="0,5" FontSize="14" HorizontalContentAlignment="Left" Padding="15,0,0,0" Click="BtnMenuHistory_Click"/>
                <Button Content="Excepții (Whitelist)" Background="Transparent" Foreground="Gray" BorderThickness="0" Height="40" Margin="0,5" FontSize="14" HorizontalContentAlignment="Left" Padding="15,0,0,0" Click="BtnMenuWhitelist_Click"/>
                <Button Content="Protecție Real-Time" Background="Transparent" Foreground="Gray" BorderThickness="0" Height="40" Margin="0,5" FontSize="14" HorizontalContentAlignment="Left" Padding="15,0,0,0" Click="BtnMenuMonitor_Click"/>
                <Button Content="File Scanning" Background="Transparent" Foreground="Gray" BorderThickness="0" Height="40" Margin="0,5" FontSize="14" HorizontalContentAlignment="Left" Padding="15,0,0,0" Click="BtnMenuCustomScan_Click"/>
                <Button Content="Carantină" Background="Transparent" Foreground="Gray" BorderThickness="0" Height="40" Margin="0,5" FontSize="14" HorizontalContentAlignment="Left" Padding="15,0,0,0" Click="BtnMenuQuarantine_Click"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="30">

            <Grid x:Name="ViewDashboard" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                    <Ellipse Width="15" Height="15" Fill="#00ADB5" Margin="0,0,10,0"/>
                    <TextBlock Text="Motorul de AI este activ (Model: EMBER 2018)" FontSize="14" Foreground="#EEEEEE" VerticalAlignment="Center"/>
                </StackPanel>

                <Border x:Name="DropZone" Grid.Row="1" 
                        Background="#1A1A1A" 
                        BorderBrush="#00ADB5" 
                        BorderThickness="2" 
                        CornerRadius="10"
                        AllowDrop="True"
                        DragEnter="DropZone_DragEnter"
                        Drop="DropZone_Drop">

                    <Grid>
                        <StackPanel x:Name="UploadPrompt" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="⤓" FontSize="60" HorizontalAlignment="Center" Foreground="#00ADB5"/>
                            <TextBlock Text="Trage un fișier executabil (.exe) aici pentru scanare" FontSize="16" Margin="0,10,0,5" HorizontalAlignment="Center"/>
                            <TextBlock Text="Analiză Machine Learning Zero-Day statică" FontSize="12" Foreground="Gray" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel x:Name="ResultPanel" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
                            <TextBlock x:Name="TxtVerdict" Text="SCANAND..." FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TxtScor" Text="Calculare probabilitate..." FontSize="18" Margin="0,10,0,20" HorizontalAlignment="Center"/>

                            <StackPanel x:Name="ActionButtons" Orientation="Horizontal" HorizontalAlignment="Center" Visibility="Collapsed">
                                <Button Content="Pune în Carantină" Background="#FF2E93" Foreground="White" Width="130" Height="35" Margin="5" BorderThickness="0" Click="Quarantine_Click"/>
                                <Button Content="Șterge Fișier" Background="#D9534F" Foreground="White" Width="100" Height="35" Margin="5" BorderThickness="0" Click="Delete_Click"/>
                                <Button Content="Iartă (Whitelist)" Background="#00ADB5" Foreground="White" Width="110" Height="35" Margin="5" BorderThickness="0" Click="AllowThreat_Click"/>
                            </StackPanel>

                            <Button x:Name="BtnRefreshDashboard" Content="🔄 Refresh" Background="#333333" Foreground="White" Width="120" Height="30" Margin="0,20,0,0" BorderThickness="0" Cursor="Hand" Click="BtnReset_Click"/>
                        
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Grid x:Name="ViewHistory" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Istoric Scanări" FontSize="22" FontWeight="Bold" Foreground="#00ADB5" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Șterge Tot Istoricul" Background="#D9534F" Foreground="White" BorderThickness="0" Padding="15,5" Cursor="Hand" Click="BtnClearHistory_Click"/>
                </Grid>
                
                <DataGrid x:Name="GridHistory" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" 
                          Background="White" RowBackground="White" AlternatingRowBackground="#F0F0F0" Foreground="Black">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Data" Binding="{Binding ScanDate, StringFormat=\{0:dd/MM/yyyy HH:mm\}}" Width="120"/>
                        <DataGridTextColumn Header="Fișier" Binding="{Binding FileName}" Width="*"/>
                        <DataGridTextColumn Header="Verdict" Binding="{Binding Verdict}" Width="80"/>
                        <DataGridTextColumn Header="Încredere AI" Binding="{Binding ConfidenceScore, StringFormat=\{0:F2\}%}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <Grid x:Name="ViewWhitelist" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Fișiere Permise (Exceptate)" FontSize="22" FontWeight="Bold" Foreground="#00ADB5" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Adaugă Excepție" Background="#00ADB5" Foreground="White" BorderThickness="0" Padding="15,5" Margin="0,0,10,0" Cursor="Hand" Click="BtnAddWhitelist_Click"/>
                        <Button Content="Elimină Selectat" Background="#D9534F" Foreground="White" BorderThickness="0" Padding="15,5" Cursor="Hand" Click="BtnRemoveWhitelist_Click"/>
                    </StackPanel>
                </Grid>
                
                <DataGrid x:Name="GridWhitelist" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" 
                          Background="White" RowBackground="White" AlternatingRowBackground="#F0F0F0" Foreground="Black"
                          SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Adăugat la" Binding="{Binding AddedDate, StringFormat=\{0:dd/MM/yyyy\}}" Width="100"/>
                        <DataGridTextColumn Header="Fișier Exceptat" Binding="{Binding FileName}" Width="150"/>
                        <DataGridTextColumn Header="Hash (SHA256)" Binding="{Binding FileHash}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <Grid x:Name="ViewMonitor" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Foldere Protejate Activat (Real-Time)" FontSize="22" FontWeight="Bold" Foreground="#00ADB5" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Adaugă Folder" Background="#00ADB5" Foreground="White" BorderThickness="0" Padding="15,5" Margin="0,0,10,0" Cursor="Hand" Click="BtnAddFolder_Click"/>
                        <Button Content="Oprește Monitorizarea" Background="#D9534F" Foreground="White" BorderThickness="0" Padding="15,5" Cursor="Hand" Click="BtnRemoveFolder_Click"/>
                    </StackPanel>
                </Grid>

                <ListBox x:Name="ListFolders" Grid.Row="1" Background="White" Foreground="Black" FontSize="16" Padding="10" SelectionMode="Single"/>
            </Grid>

            <Grid x:Name="ViewCustomScan" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Scanare Multiplă (La Cerere)" FontSize="22" FontWeight="Bold" Foreground="#00ADB5" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Selectează Fișiere..." Background="#00ADB5" Foreground="White" BorderThickness="0" Padding="15,5" Cursor="Hand" Click="BtnSelectFilesToScan_Click"/>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#1A1A1A" BorderBrush="Gray" BorderThickness="1" CornerRadius="10" Margin="0,0,5,0">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="⏳ În Așteptare (Queue)" Foreground="White" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                            <ListBox x:Name="ListQueue" Grid.Row="1" Background="Transparent" Foreground="LightGray" BorderThickness="0"/>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Background="#1A1A1A" BorderBrush="LimeGreen" BorderThickness="1" CornerRadius="10" Margin="5,0,5,0">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="✔️ Fișiere Sigure" Foreground="LimeGreen" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                            <ListBox x:Name="ListSafe" Grid.Row="1" Background="Transparent" Foreground="LimeGreen" BorderThickness="0"/>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Background="#1A1A1A" BorderBrush="Red" BorderThickness="1" CornerRadius="10" Margin="5,0,0,0">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="❌ Malware Detectat" Foreground="Red" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                            <ListBox x:Name="ListMalware" Grid.Row="1" Background="Transparent" Foreground="Red" BorderThickness="0"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
            <Grid x:Name="ViewQuarantine" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Carantină (Fișiere Izolate)" FontSize="22" FontWeight="Bold" Foreground="#00ADB5" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Restaurează Fișier" Background="#00ADB5" Foreground="White" BorderThickness="0" Padding="15,5" Margin="0,0,10,0" Cursor="Hand" Click="BtnRestoreQuarantine_Click"/>
                        <Button Content="Șterge Definitiv" Background="#D9534F" Foreground="White" BorderThickness="0" Padding="15,5" Cursor="Hand" Click="BtnDeleteQuarantine_Click"/>
                    </StackPanel>
                </Grid>

                <DataGrid x:Name="GridQuarantine" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" 
                          Background="White" RowBackground="White" AlternatingRowBackground="#F0F0F0" Foreground="Black"
                          SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Data Izolării" Binding="{Binding QuarantineDate, StringFormat=\{0:dd/MM/yyyy HH:mm\}}" Width="130"/>
                        <DataGridTextColumn Header="Nume Fișier" Binding="{Binding FileName}" Width="150"/>
                        <DataGridTextColumn Header="Locație Originală" Binding="{Binding OriginalPath}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

        </Grid>
    </Grid>
</Window>