<Window x:Class="CortexAV.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CortexAV"
        mc:Ignorable="d"
        Title="CortexAV - Zero-Day Malware Detector" Height="550" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#121212" Foreground="White">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#1E1E1E" Grid.Column="0" CornerRadius="0,15,15,0">
            <StackPanel Margin="10,30,10,10">
                <TextBlock Text="CortexAV" FontSize="26" FontWeight="Bold" Foreground="#00ADB5" HorizontalAlignment="Center" Margin="0,0,0,40"/>

                <Button Content="Dashboard" Background="Transparent" Foreground="White" BorderThickness="0" Height="40" Margin="0,5" FontSize="14" HorizontalContentAlignment="Left" Padding="15,0,0,0"/>
                <Button Content="Carantină" Background="Transparent" Foreground="Gray" BorderThickness="0" Height="40" Margin="0,5" FontSize="14" HorizontalContentAlignment="Left" Padding="15,0,0,0"/>
                <Button Content="Setări" Background="Transparent" Foreground="Gray" BorderThickness="0" Height="40" Margin="0,5" FontSize="14" HorizontalContentAlignment="Left" Padding="15,0,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                <Ellipse Width="15" Height="15" Fill="#00ADB5" Margin="0,0,10,0"/>
                <TextBlock Text="Motorul de AI este activ (Model: EMBER 2018)" FontSize="14" Foreground="#EEEEEE" VerticalAlignment="Center"/>
            </StackPanel>

            <Border x:Name="DropZone" Grid.Row="1" 
                    Background="#1A1A1A" 
                    BorderBrush="#00ADB5" 
                    BorderThickness="2" 
                    CornerRadius="10"
                    AllowDrop="True"
                    DragEnter="DropZone_DragEnter"
                    Drop="DropZone_Drop">

                <Grid>
                    <StackPanel x:Name="UploadPrompt" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="⤓" FontSize="60" HorizontalAlignment="Center" Foreground="#00ADB5"/>
                        <TextBlock Text="Trage un fișier executabil (.exe) aici pentru scanare" FontSize="16" Margin="0,10,0,5" HorizontalAlignment="Center"/>
                        <TextBlock Text="Analiză Machine Learning Zero-Day statică" FontSize="12" Foreground="Gray" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel x:Name="ResultPanel" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
                        <TextBlock x:Name="TxtVerdict" Text="SCANAND..." FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TxtScor" Text="Calculare probabilitate..." FontSize="18" Margin="0,10,0,20" HorizontalAlignment="Center"/>

                        <StackPanel x:Name="ActionButtons" Orientation="Horizontal" HorizontalAlignment="Center" Visibility="Collapsed">
                            <Button Content="Pune în Carantină" Background="#FF2E93" Foreground="White" Width="140" Height="35" Margin="5" BorderThickness="0" Click="Quarantine_Click"/>
                            <Button Content="Șterge Fișier" Background="#D9534F" Foreground="White" Width="120" Height="35" Margin="5" BorderThickness="0" Click="Delete_Click"/>
                        </StackPanel>

                        <Button x:Name="BtnReset" Content="Scanează alt fișier" Background="#333333" Foreground="White" Width="150" Height="30" Margin="0,20,0,0" BorderThickness="0" Click="BtnReset_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>